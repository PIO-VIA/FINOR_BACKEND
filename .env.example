# Database
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://finor_user:yourpassword@localhost:5432/finor_db

# JWT
SECRET_KEY=change_this_to_a_long_random_secret_key_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# First treasurer account (used by the seed script)
FIRST_TREASURER_NAME=Admin
FIRST_TREASURER_EMAIL=admin@finor.local
FIRST_TREASURER_PASSWORD=change_this_password
